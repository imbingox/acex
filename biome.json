{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsole": "error"
      },
      "style": {
        "noNonNullAssertion": "error"
      },
      "complexity": {
        "noBannedTypes": "off"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!.agents",
      "!.claude",
      "!.trellis",
      "!coverage",
      "!dist",
      "!docs",
      "!node_modules"
    ]
  }
}
